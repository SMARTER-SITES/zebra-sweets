---
import { navigation, siteMeta } from "../data/site";

const currentPath = Astro.url.pathname;
const isCurrent = (href) => currentPath === href;
const isParentCurrent = (item) => isCurrent(item.href) || item.items?.some((subItem) => isCurrent(subItem.href));
const desktopNavigation = navigation.filter((item) => item.href !== "/kontakt/");
---

<header id="site-header" data-scrolled="false" class="site-header sticky top-2 z-50 px-3 pt-3 sm:top-3 sm:px-5 sm:pt-5">
	<div class="site-header__shell relative mx-auto max-w-[var(--frame-width)] overflow-visible rounded-[1.6rem] border border-white/75 bg-[linear-gradient(180deg,rgba(255,255,255,0.97)_0%,rgba(247,247,249,0.92)_42%,rgba(238,238,241,0.88)_100%)] shadow-[0_22px_60px_rgba(12,12,14,0.12),inset_0_1px_0_rgba(255,255,255,0.98),inset_0_-1px_0_rgba(255,255,255,0.62)] backdrop-blur-3xl">
		<div class="site-header__glow site-header__glow--center pointer-events-none absolute left-1/2 top-[-2.8rem] h-24 w-[42%] -translate-x-1/2 rounded-full bg-white/85 blur-3xl"></div>
		<div class="site-header__glow site-header__glow--edge pointer-events-none absolute right-8 top-3 h-16 w-40 rounded-full bg-white/65 blur-2xl"></div>
		<div class="site-header__shine pointer-events-none absolute inset-x-4 top-1 h-10 rounded-full bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,rgba(255,255,255,0.36)_72%,transparent_100%)] blur-[1.5px]"></div>
		<div class="relative flex h-[72px] items-center justify-between gap-4 px-4 sm:px-6 lg:px-7">
			<a href="/" class="shrink-0">
				<img
					src={siteMeta.logo}
					alt={siteMeta.siteName}
					class="h-auto max-h-[80px] w-[4.1rem] object-contain drop-shadow-[0_8px_20px_rgba(12,12,14,0.08)] sm:w-[4.5rem]"
				/>
			</a>

			<nav class="site-header__nav hidden max-w-max items-center gap-0.5 rounded-full border border-white/90 bg-[linear-gradient(180deg,rgba(255,255,255,0.99)_0%,rgba(246,246,248,0.96)_52%,rgba(238,238,241,0.92)_100%)] px-1.5 py-1 shadow-[inset_0_1px_0_rgba(255,255,255,0.98),inset_0_-1px_0_rgba(255,255,255,0.55),0_12px_28px_rgba(12,12,14,0.07)] lg:flex">
			{desktopNavigation.map((item) =>
				item.items ? (
					<div class="site-header__dropdown group relative">
						<a
							href={item.href}
							class:list={[
								"inline-flex h-9 items-center gap-2 rounded-full px-3 py-0 text-[0.92rem] font-medium leading-none transition",
								isParentCurrent(item)
									? "bg-[var(--accent)] !text-white shadow-[0_8px_18px_rgba(18,18,18,0.18)]"
									: "text-[var(--ink)] hover:bg-black/[0.05]",
							]}
						>
							{item.label}
							<svg
								viewBox="0 0 10 6"
								aria-hidden="true"
								class:list={[
									"h-2.5 w-2.5 transition duration-200 group-hover:translate-y-[1px]",
									isParentCurrent(item) ? "text-white" : "text-current",
								]}
							>
								<path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" />
							</svg>
						</a>

						<div class="pointer-events-none invisible absolute left-1/2 top-full z-50 w-max min-w-[15rem] -translate-x-1/2 translate-y-2 opacity-0 transition duration-200 group-hover:pointer-events-auto group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
							<div class="pt-3">
								<div class="site-header__submenu rounded-[1.4rem] border border-white/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.98)_0%,rgba(245,245,247,0.95)_100%)] p-2 shadow-[0_24px_48px_rgba(12,12,14,0.12),inset_0_1px_0_rgba(255,255,255,0.98)] backdrop-blur-2xl">
									{item.items.map((subItem) => (
										<a
											href={subItem.href}
											class:list={[
												"block rounded-[1rem] px-4 py-3 text-sm font-medium transition",
												isCurrent(subItem.href)
													? "bg-[var(--accent)] !text-white shadow-[0_8px_18px_rgba(18,18,18,0.14)]"
													: "text-[var(--ink)] hover:bg-black/[0.04]",
											]}
										>
											{subItem.label}
										</a>
									))}
								</div>
							</div>
						</div>
					</div>
				) : (
					<a
						href={item.href}
						class:list={[
							"inline-flex h-9 items-center rounded-full px-3 py-0 text-[0.92rem] font-medium leading-none transition",
							isCurrent(item.href)
								? "bg-[var(--accent)] !text-white shadow-[0_8px_18px_rgba(18,18,18,0.18)]"
								: "text-[var(--ink)] hover:bg-black/[0.05]",
						]}
					>
						{item.label}
					</a>
				),
			)}
			</nav>

			<div class="flex items-center gap-2">
				<a href="/kontakt/" class="site-header__cta hidden h-10 items-center rounded-full border border-black/5 bg-[linear-gradient(180deg,#1d1d1f_0%,#080809_100%)] px-5 py-0 text-xs font-semibold uppercase tracking-[0.18em] !text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.12),0_12px_24px_rgba(18,18,18,0.2)] lg:inline-flex">
					Kontakt
				</a>
				<button
					id="menu-toggle"
					class="site-header__menu inline-flex size-11 items-center justify-center rounded-full border border-white/90 bg-[linear-gradient(180deg,rgba(255,255,255,0.99)_0%,rgba(244,244,247,0.92)_100%)] shadow-[inset_0_1px_0_rgba(255,255,255,0.98),0_10px_24px_rgba(12,12,14,0.08)] lg:hidden"
					aria-label="Open menu"
					aria-expanded="false"
				>
					<span class="sr-only">Meni</span>
					<span class="block h-0.5 w-5 bg-[var(--accent)] shadow-[0_7px_0_var(--accent),0_-7px_0_var(--accent)]"></span>
				</button>
			</div>
		</div>

		<nav id="mobile-menu" class="site-header__mobile-menu hidden border-t border-white/75 bg-[linear-gradient(180deg,rgba(255,255,255,0.97)_0%,rgba(243,243,246,0.94)_100%)] lg:hidden">
			<div class="container-shell grid gap-2 py-4">
				{navigation.map((item, index) => (
					<div class="grid gap-2">
						{item.href === "/kontakt/" ? (
							<div class="grid gap-2">
								<a
									href="/kontakt/#maloprodaja"
									class="rounded-2xl px-4 py-3 text-sm font-medium transition bg-white/85 text-[var(--ink)]"
								>
									Maloprodaja
								</a>
								<a
									href="/kontakt/#direktan-kontakt"
									class:list={[
										"rounded-2xl px-4 py-3 text-sm font-medium transition",
										isCurrent("/kontakt/") ? "bg-[var(--accent)] !text-white" : "bg-white/85 text-[var(--ink)]",
									]}
								>
									Kontakt
								</a>
							</div>
						) : item.items ? (
							<div class="grid gap-2">
								<div class="grid grid-cols-[1fr_auto] gap-2">
									<a
										href={item.href}
										class:list={[
											"rounded-2xl px-4 py-3 text-sm font-medium transition",
											isParentCurrent(item) ? "bg-[var(--accent)] !text-white" : "bg-white/85 text-[var(--ink)]",
										]}
									>
										{item.label}
									</a>
									<button
										type="button"
										class="inline-flex items-center justify-center rounded-2xl border border-white/90 bg-white/85 px-4 py-3 text-[var(--ink)] transition"
										data-mobile-submenu-toggle
										data-target={`mobile-submenu-${index}`}
										aria-controls={`mobile-submenu-${index}`}
										aria-expanded={isParentCurrent(item) ? "true" : "false"}
										aria-label={`Prikaži podmeni za ${item.label}`}
									>
										<svg
											viewBox="0 0 10 6"
											aria-hidden="true"
											class:list={[
												"h-2.5 w-2.5 transition duration-200",
												isParentCurrent(item) ? "rotate-180" : "",
											]}
										>
											<path d="M1 1l4 4 4-4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.3" />
										</svg>
									</button>
								</div>
								<div
									id={`mobile-submenu-${index}`}
									class:list={[
										"grid gap-2 pl-4",
										!isParentCurrent(item) && "hidden",
									]}
									data-mobile-submenu
								>
									{item.items.map((subItem) => (
										<a
											href={subItem.href}
											class:list={[
												"rounded-2xl border border-white/90 px-4 py-3 text-sm transition",
												isCurrent(subItem.href)
													? "bg-black text-white shadow-[0_10px_18px_rgba(12,12,14,0.12)]"
													: "bg-white/72 text-[var(--ink)]",
											]}
										>
											{subItem.label}
										</a>
									))}
								</div>
							</div>
						) : (
							<a
								href={item.href}
								class:list={[
									"rounded-2xl px-4 py-3 text-sm font-medium transition",
									isParentCurrent(item) ? "bg-[var(--accent)] !text-white" : "bg-white/85 text-[var(--ink)]",
								]}
							>
								{item.label}
							</a>
						)}
					</div>
				))}
			</div>
		</nav>
	</div>
</header>

<script is:inline>
	const header = document.getElementById("site-header");
	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");

	const closeMenu = () => {
		if (!toggle || !menu) return;
		menu.classList.add("hidden");
		toggle.setAttribute("aria-expanded", "false");
	};

	const syncHeaderScrollState = () => {
		if (!header) return;
		header.dataset.scrolled = window.scrollY > 18 ? "true" : "false";
	};

	if (toggle && menu) {
		toggle.addEventListener("click", () => {
			const isOpen = !menu.classList.contains("hidden");
			menu.classList.toggle("hidden", isOpen);
			toggle.setAttribute("aria-expanded", String(!isOpen));
		});

		menu.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			const submenuToggle = target.closest("[data-mobile-submenu-toggle]");
			if (submenuToggle instanceof HTMLButtonElement) {
				event.preventDefault();
				const submenuId = submenuToggle.dataset.target;
				if (!submenuId) return;
				const submenu = document.getElementById(submenuId);
				if (!submenu) return;
				const isExpanded = submenuToggle.getAttribute("aria-expanded") === "true";
				submenu.classList.toggle("hidden", isExpanded);
				submenuToggle.setAttribute("aria-expanded", String(!isExpanded));
				const icon = submenuToggle.querySelector("svg");
				if (icon) icon.classList.toggle("rotate-180", !isExpanded);
				return;
			}

			const link = target.closest("a");
			if (link) closeMenu();
		});
	}

	syncHeaderScrollState();
	window.addEventListener("scroll", syncHeaderScrollState, { passive: true });
</script>
